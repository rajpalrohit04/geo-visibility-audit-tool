# Copy this file to .env and fill in your own values.
# .env is gitignored, it will never be committed.

# Required baseline providers
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Optional: add either or both to test brand visibility on these models too.
# Leave blank to skip; the tool runs fine with just Claude + GPT.
GEMINI_API_KEY=
PERPLEXITY_API_KEY=

# Optional: override default models
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.4-mini
GEMINI_MODEL=gemini-2.5-flash
PERPLEXITY_MODEL=sonar

# Optional: only needed if you want results exported to Google Sheets.
# GOOGLE_SERVICE_ACCOUNT_FILE is a path to a service account JSON key file
# (see https://developers.google.com/workspace/guides/create-credentials).
# Leave both blank to skip the Sheets export; the terminal report still
# prints in full either way.
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SHEET_ID=
